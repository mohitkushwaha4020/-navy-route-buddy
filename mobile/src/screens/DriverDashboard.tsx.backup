import React, { useState, useEffect, useRef } from 'react';
import { View, Text, StyleSheet, TouchableOpacity, ScrollView, Alert, PermissionsAndroid, Platform, Modal, Switch, Image } from 'react-native';
import MapView, { Marker, Polyline } from 'react-native-maps';
import { useAuth } from '../contexts/AuthContext';
import { supabase } from '../lib/supabase';
import LocationService from '../services/LocationService';

export default function DriverDashboard({ navigation }: any) {
  const { signOut, user } = useAuth();
  const [location, setLocation] = useState<any>(null);
  const [tracking, setTracking] = useState(false);
  const [routeInfo, setRouteInfo] = useState<any>(null);
  const [studentsCount, setStudentsCount] = useState(0);
  const [profileModalVisible, setProfileModalVisible] = useState(false);
  const [batterySaver, setBatterySaver] = useState(false);
  const [offlineQueueSize, setOfflineQueueSize] = useState(0);
  const [routePath, setRoutePath] = useState<any[]>([]);
  const [busStops, setBusStops] = useState<string[]>([]);
  const [busInfo, setBusInfo] = useState<any>(null);
  const mapRef = useRef<MapView>(null);

  useEffect(() => {
    requestLocationPermission();
    fetchRouteInfo();
    fetchBusInfo();
    getInitialLocation();
    
    // Update offline queue size periodically
    const queueInterval = setInterval(() => {
      setOfflineQueueSize(LocationService.getOfflineQueueSize());
    }, 5000);
    
    return () => {
      LocationService.stopTracking();
      clearInterval(queueInterval);
    };
  }, []);

  useEffect(() => {
    if (tracking) {
      startLocationTracking();
    } else {
      stopLocationTracking();
    }
  }, [tracking, batterySaver]);

  const requestLocationPermission = async () => {
    if (Platform.OS === 'android') {
      try {
        const granted = await PermissionsAndroid.requestMultiple([
          PermissionsAndroid.PERMISSIONS.ACCESS_FINE_LOCATION,
          PermissionsAndroid.PERMISSIONS.ACCESS_BACKGROUND_LOCATION,
        ]);
        
        if (
          granted['android.permission.ACCESS_FINE_LOCATION'] !== PermissionsAndroid.RESULTS.GRANTED
        ) {
          Alert.alert('Permission denied', 'Location permission is required');
          return;
        }
        
        if (
          granted['android.permission.ACCESS_BACKGROUND_LOCATION'] !== PermissionsAndroid.RESULTS.GRANTED
        ) {
          Alert.alert(
            'Background Location',
            'For continuous tracking, please enable background location access in settings'
          );
        }
      } catch (err) {
        console.warn(err);
        return;
      }
    }
  };

  const getInitialLocation = async () => {
    const currentLocation = await LocationService.getCurrentLocation();
    if (currentLocation) {
      setLocation({
        latitude: currentLocation.latitude,
        longitude: currentLocation.longitude,
      });
      
      // Center map on current location
      if (mapRef.current) {
        mapRef.current.animateToRegion({
          latitude: currentLocation.latitude,
          longitude: currentLocation.longitude,
          latitudeDelta: 0.01,
          longitudeDelta: 0.01,
        });
      }
    }
  };

  const fetchRouteInfo = async () => {
    try {
      const { data: route } = await supabase
        .from('routes')
        .select(`
          *,
          route_students(count)
        `)
        .eq('driver_id', user?.id)
        .single();

      if (route) {
        setRouteInfo(route);
        setStudentsCount(route.route_students?.[0]?.count || 0);
      }
    } catch (error) {
      console.error('Error fetching route:', error);
    }
  };

  const fetchBusInfo = async () => {
    try {
      const { data: bus, error } = await supabase
        .from('buses')
        .select('*')
        .eq('driver_email', user?.email)
        .single();

      if (error) throw error;
      if (bus) {
        setBusInfo(bus);
        setBusStops(bus.stops || []);
      }
    } catch (error) {
      console.error('Error fetching bus info:', error);
    }
  };

  const startLocationTracking = async () => {
    if (!user?.id) return;

    await LocationService.startTracking(
      user.id,
      batterySaver,
      (locationData) => {
        const newLocation = {
          latitude: locationData.latitude,
          longitude: locationData.longitude,
          accuracy: locationData.accuracy,
          speed: locationData.speed,
          heading: locationData.heading,
        };
        
        setLocation(newLocation);
        
        // Add to route path for visualization
        setRoutePath((prev) => [...prev.slice(-50), newLocation]); // Keep last 50 points
        
        // Update offline queue size
        setOfflineQueueSize(LocationService.getOfflineQueueSize());
      }
    );
  };

  const stopLocationTracking = () => {
    LocationService.stopTracking();
    setRoutePath([]);
  };

  const toggleTracking = async () => {
    const newTrackingState = !tracking;
    setTracking(newTrackingState);
    
    // Update route status
    if (routeInfo) {
      try {
        await supabase
          .from('routes')
          .update({ status: newTrackingState ? 'active' : 'inactive' })
          .eq('id', routeInfo.id);
      } catch (error) {
        console.error('Error updating route status:', error);
      }
    }
    
    Alert.alert(
      newTrackingState ? 'Tracking Started' : 'Tracking Stopped',
      newTrackingState ? 'Students can now see your location' : 'Location sharing disabled'
    );
  };

  const handleLogout = async () => {
    try {
      await signOut();
      navigation.replace('Login');
    } catch (error: any) {
      Alert.alert('Error', error.message);
    }
  };

  return (
    <View style={styles.container}>
      <View style={styles.header}>
        <View>
          <Text style={styles.title}>Driver Dashboard</Text>
          <Text style={styles.email}>{user?.email}</Text>
        </View>
        <TouchableOpacity 
          style={styles.profileButton}
          onPress={() => setProfileModalVisible(true)}
        >
          <Text style={styles.profileIcon}>👤</Text>
        </TouchableOpacity>
      </View>

      <ScrollView>
        {/* Bus Route & Stops Card - Show First */}
        {busInfo && (
          <View style={styles.infoCard}>
            <Text style={styles.cardTitle}>🚌 Your Bus Information</Text>
            <Text style={styles.cardText}>
              Bus Number: {busInfo.bus_number}
            </Text>
            <Text style={styles.cardText}>
              Route: {busInfo.route_number}
            </Text>
            <Text style={styles.cardText}>
              Total Stops: {busStops.length}
            </Text>
          </View>
        )}

        {/* Bus Stops Preview - Show Before Start Button */}
        {busStops.length > 0 && (
          <View style={styles.stopsCard}>
            <Text style={styles.cardTitle}>📍 Your Pickup Points</Text>
            <Text style={styles.stopsSubtitle}>
              Stop at these locations to pick up students:
            </Text>
            {busStops.map((stop, index) => (
              <View key={index} style={styles.stopItem}>
                <View style={styles.stopNumber}>
                  <Text style={styles.stopNumberText}>{index + 1}</Text>
                </View>
                <Text style={styles.stopText}>{stop}</Text>
              </View>
            ))}
          </View>
        )}

        {/* Battery Saver Toggle - Before Start Button */}
        {!tracking && (
          <View style={styles.settingsCard}>
            <View style={styles.settingRow}>
              <View>
                <Text style={styles.settingLabel}>Battery Saver Mode</Text>
                <Text style={styles.settingDescription}>
                  {batterySaver ? 'Lower accuracy, less battery' : 'High accuracy, more battery'}
                </Text>
              </View>
              <Switch
                value={batterySaver}
                onValueChange={setBatterySaver}
                disabled={tracking}
              />
            </View>
          </View>
        )}

        {/* Start/Stop Tracking Button */}
        <TouchableOpacity 
          style={[styles.trackButton, tracking && styles.trackButtonActive]}
          onPress={toggleTracking}
        >
          <Text style={styles.trackButtonText}>
            {tracking ? '⏹️ Stop Tracking' : '▶️ Start Tracking'}
          </Text>
        </TouchableOpacity>

        {/* Map - Show Only When Tracking is Active */}
        {tracking && location && (
          <View style={styles.mapContainer}>
            <Text style={styles.mapTitle}>�️  Live Route Map</Text>
            <MapView
              ref={mapRef}
              style={styles.map}
              initialRegion={{
                latitude: location.latitude,
                longitude: location.longitude,
                latitudeDelta: 0.01,
                longitudeDelta: 0.01,
              }}
              showsUserLocation={true}
              showsMyLocationButton={true}
              followsUserLocation={tracking}
            >
              <Marker
                coordinate={{
                  latitude: location.latitude,
                  longitude: location.longitude,
                }}
                title="Bus Location"
                description={`Speed: ${location.speed ? (location.speed * 3.6).toFixed(1) : '0'} km/h`}
                pinColor="red"
              />
              
              {/* Show route path */}
              {routePath.length > 1 && (
                <Polyline
                  coordinates={routePath}
                  strokeColor="#3b82f6"
                  strokeWidth={3}
                />
              )}
            </MapView>
          </View>
        )}

        {/* Tracking Information Card - Show When Active */}
        {tracking && (
          <View style={styles.infoCard}>
            <Text style={styles.cardTitle}>📊 Live Tracking Status</Text>
            <Text style={styles.cardText}>
              Status: 🟢 Active - Students can see your location
            </Text>
            <Text style={styles.cardText}>
              Students Tracking: {studentsCount}
            </Text>
            {location && (
              <>
                <Text style={styles.cardText}>
                  Speed: {location.speed ? `${(location.speed * 3.6).toFixed(1)} km/h` : '0 km/h'}
                </Text>
                <Text style={styles.cardText}>
                  Accuracy: {location.accuracy ? `±${location.accuracy.toFixed(0)}m` : 'N/A'}
                </Text>
                {location.heading !== null && (
                  <Text style={styles.cardText}>
                    Heading: {location.heading.toFixed(0)}°
                  </Text>
                )}
              </>
            )}
            {offlineQueueSize > 0 && (
              <Text style={styles.cardTextWarning}>
                ⚠️ {offlineQueueSize} location(s) pending upload
              </Text>
            )}
            <Text style={styles.cardText}>
              Mode: {batterySaver ? '🔋 Battery Saver' : '⚡ High Accuracy'}
            </Text>
          </View>
        )}

        {/* Info Message When Not Tracking */}
        {!tracking && (
          <View style={styles.infoMessageCard}>
            <Text style={styles.infoMessageIcon}>ℹ️</Text>
            <Text style={styles.infoMessageText}>
              Review your pickup points above, then tap "Start Tracking" to begin your route. 
              The map will appear once tracking starts.
            </Text>
          </View>
        )}
      </ScrollView>

      {/* Profile Modal */}
      <Modal
        visible={profileModalVisible}
        transparent
        animationType="slide"
        onRequestClose={() => setProfileModalVisible(false)}
      >
        <View style={styles.modalOverlay}>
          <View style={styles.modalContent}>
            <View style={styles.modalHeader}>
              <Text style={styles.modalTitle}>👤 Driver Profile</Text>
              <TouchableOpacity onPress={() => setProfileModalVisible(false)}>
                <Text style={styles.closeButton}>✕</Text>
              </TouchableOpacity>
            </View>

            {/* Driver Photo Section */}
            {busInfo && (
              <View style={styles.photoSection}>
                {busInfo.driver_photo_url ? (
                  <Image 
                    source={{ uri: busInfo.driver_photo_url }} 
                    style={styles.profilePhotoLarge}
                  />
                ) : (
                  <View style={styles.profilePhotoPlaceholder}>
                    <Text style={styles.profilePhotoPlaceholderText}>👤</Text>
                  </View>
                )}
              </View>
            )}

            <View>
              {/* Driver Name */}
              {busInfo?.driver_full_name && (
                <View style={styles.profileRow}>
                  <Text style={styles.profileLabel}>Full Name:</Text>
                  <Text style={styles.profileValue}>{busInfo.driver_full_name}</Text>
                </View>
              )}
              
              {/* Driver Email */}
              <View style={styles.profileRow}>
                <Text style={styles.profileLabel}>Email:</Text>
                <Text style={styles.profileValue}>{user?.email}</Text>
              </View>
              
              {/* Driver Mobile */}
              {busInfo?.driver_mobile && (
                <View style={styles.profileRow}>
                  <Text style={styles.profileLabel}>Mobile:</Text>
                  <Text style={styles.profileValue}>{busInfo.driver_mobile}</Text>
                </View>
              )}
              
              {/* User ID */}
              <View style={styles.profileRow}>
                <Text style={styles.profileLabel}>User ID:</Text>
                <Text style={styles.profileValue}>{user?.id?.substring(0, 8)}...</Text>
              </View>
              
              {/* Role Badge */}
              <View style={styles.profileRow}>
                <Text style={styles.profileLabel}>Role:</Text>
                <View style={styles.roleBadge}>
                  <Text style={styles.roleBadgeText}>🚗 Driver</Text>
                </View>
              </View>
              
              {/* Bus Information */}
              {busInfo && (
                <>
                  <View style={styles.profileRow}>
                    <Text style={styles.profileLabel}>Bus Number:</Text>
                    <Text style={styles.profileValue}>{busInfo.bus_number}</Text>
                  </View>
                  <View style={styles.profileRow}>
                    <Text style={styles.profileLabel}>Route:</Text>
                    <Text style={styles.profileValue}>{busInfo.route_number}</Text>
                  </View>
                  <View style={styles.profileRow}>
                    <Text style={styles.profileLabel}>Total Stops:</Text>
                    <Text style={styles.profileValue}>{busStops.length}</Text>
                  </View>
                </>
              )}
            </View>

            <TouchableOpacity 
              style={styles.closeModalButton}
              onPress={() => setProfileModalVisible(false)}
            >
              <Text style={styles.closeModalText}>Close</Text>
            </TouchableOpacity>
          </View>
        </View>
      </Modal>
    </View>
  );
}

